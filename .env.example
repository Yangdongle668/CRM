# ============================================================
# CRM 部署配置 — 复制此文件为 .env 并填入真实值
# cp .env.example .env
# ============================================================

# 你的访问地址（IP 或域名），邮件追踪链接会用到
# 用 IP：  APP_URL=http://123.456.789.000
# 用域名： APP_URL=https://your-domain.com
APP_URL=http://localhost

# 数据库密码（随便填一个复杂字符串）
DB_PASSWORD=change-me-db-password

# JWT 密钥（随便填一个复杂字符串）
JWT_SECRET=change-me-jwt-secret
