generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== 用户与角色 ====================
// 注意：原先的 Role 枚举已替换为 Role 表 + User.role 字符串字段，
// 从而支持管理员在运行时新增自定义角色。旧数据里的 "ADMIN"/"SALESPERSON"/
// "FINANCE" 值原样保留，ADMIN 仍然是内置且不可删除的。

// ==================== 动态权限 (RBAC) ====================
// Role 表：系统支持的角色集合（内置 + 自定义）。
// Permission 表：系统可用的权限码（如 "customer:delete"）。
// RolePermission 表：角色 → 权限的多对多映射。
// 管理员角色约定授予 "*" 通配符 → 拥有所有权限。
model Role {
  id          String   @id @default(uuid())
  code        String   @unique // 稳定的机器可读代码，例如 "SALESPERSON" 或 "MARKETING"
  name        String           // 显示名，例如 "销售员"
  description String?
  isBuiltin   Boolean  @default(false) @map("is_builtin") // 内置角色不允许删除 / 改 code
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("roles")
}

model Permission {
  id          String           @id @default(uuid())
  code        String           @unique
  name        String
  description String?
  category    String?
  createdAt   DateTime         @default(now()) @map("created_at")
  rolePerms   RolePermission[]

  @@map("permissions")
}

model RolePermission {
  id           String     @id @default(uuid())
  role         String     // 对应 Role.code；用字符串是为兼容旧数据 & 灵活
  permissionId String     @map("permission_id")
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now()) @map("created_at")

  @@unique([role, permissionId])
  @@index([role])
  @@map("role_permissions")
}

// ==================== 审计日志 (Audit Log) ====================
// 记录"谁、在哪、对什么、做了什么、什么时候"的事件，用于安全追溯与合规。
// - action: 业务动作码，约定 "<resource>.<verb>"（如 customer.delete / order.price.update）
// - targetType/targetId: 操作对象（可空，例如登录事件只有 user）
// - metadata: 结构化上下文（变更前后快照 / 查询参数 / 备注）
// - ip + userAgent: 请求来源，便于异常定位
// - status: SUCCESS / FAILURE, 失败时 errorMessage 存原因
model AuditLog {
  id           String   @id @default(uuid())
  userId       String?  @map("user_id")
  userEmail    String?  @map("user_email")
  userName     String?  @map("user_name")
  userRole     String?  @map("user_role")
  action       String
  targetType   String?  @map("target_type")
  targetId     String?  @map("target_id")
  targetLabel  String?  @map("target_label")
  method       String?
  path         String?
  ip           String?
  userAgent    String?  @map("user_agent") @db.Text
  status       String   @default("SUCCESS") // "SUCCESS" | "FAILURE"
  errorMessage String?  @map("error_message") @db.Text
  metadata     Json?
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([action])
  @@index([targetType, targetId])
  @@index([createdAt])
  @@map("audit_logs")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  // role 引用 Role.code（字符串）。内置角色：ADMIN / SALESPERSON / FINANCE，
  // 管理员可在 /admin/rbac 新增自定义角色并赋值给用户。
  role      String   @default("SALESPERSON")
  phone     String?
  avatar    String?
  bio       String?
  isActive  Boolean  @default(true)
  // 超级管理员 = 系统部署后创建的第一个账号（或最早的 ADMIN）。
  // 不可删除、不可降级、不可停用；删除其他用户时被删用户名下的所有
  // 客户 / 订单 / 线索 / 任务等数据会自动转移到超级管理员名下，从而
  // 避免因为外键约束导致删不掉用户。
  isSuperAdmin Boolean @default(false) @map("is_super_admin")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // 关联
  customers       Customer[]
  leadsOwned      Lead[]         @relation("LeadsOwned")
  leadsCreated    Lead[]         @relation("LeadsCreated")
  quotations      Quotation[]
  orders          Order[]
  tasks           Task[]
  activities      Activity[]
  documents       Document[]
  emailsSent      Email[]        @relation("SentEmails")
  emailConfigs    EmailConfig[]
  campaignsCreated EmailCampaign[] @relation("CampaignsCreated")
  memos           Memo[]
  pisOwned        ProformaInvoice[] @relation("PIsOwned")
  pisApproved     ProformaInvoice[] @relation("PIsApproved")
  leadActivities   LeadActivity[]
  messagesSent     Message[]      @relation("MessagesSent")
  messagesReceived Message[]      @relation("MessagesReceived")

  @@map("users")
}

// ==================== 邮件配置 ====================
model EmailConfig {
  id         String  @id @default(uuid())
  userId     String  @map("user_id")
  emailAddr  String  @map("email_addr")
  smtpHost   String  @map("smtp_host")
  smtpPort   Int     @map("smtp_port")
  smtpUser   String  @map("smtp_user")
  smtpPass   String  @map("smtp_pass")
  smtpSecure Boolean @default(true) @map("smtp_secure")
  imapHost   String  @map("imap_host")
  imapPort   Int     @map("imap_port")
  imapUser   String  @map("imap_user")
  imapPass   String  @map("imap_pass")
  imapSecure Boolean @default(true) @map("imap_secure")
  fromName   String? @map("from_name")
  signature  String?
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  emails Email[] @relation("EmailAccount")

  @@map("email_configs")
}

// ==================== 客户管理 ====================
enum CustomerStatus {
  POTENTIAL
  ACTIVE
  INACTIVE
  BLACKLISTED
}

model Customer {
  id          String         @id @default(uuid())
  companyName String         @map("company_name")
  country     String?
  address     String?
  website     String?
  website2    String?        @map("website2")
  industry    String?
  scale       String?
  source      String?
  status      CustomerStatus @default(POTENTIAL)
  remark      String?
  ownerId     String         @map("owner_id")
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")

  // 关联
  owner              User                @relation(fields: [ownerId], references: [id])
  contacts           Contact[]
  leads              Lead[]
  quotations         Quotation[]
  orders             Order[]
  activities         Activity[]
  documents          Document[]
  emails             Email[]
  proformaInvoices   ProformaInvoice[]

  @@map("customers")
}

// ==================== 联系人 ====================
model Contact {
  id         String   @id @default(uuid())
  name       String
  title      String?
  email      String?
  phone      String?
  wechat     String?
  whatsapp   String?
  isPrimary  Boolean  @default(false) @map("is_primary")
  remark     String?
  customerId String   @map("customer_id")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@map("contacts")
}

// ==================== 销售线索 ====================
enum LeadStage {
  NEW
  CONTACTED
  QUALIFIED
  PROPOSAL
  NEGOTIATION
  CLOSED_WON
  CLOSED_LOST
}

model Lead {
  id             String    @id @default(uuid())
  title          String
  companyName    String?   @map("company_name")
  contactName    String?   @map("contact_name")
  contactTitle   String?   @map("contact_title")
  contactEmail   String?   @map("contact_email")
  email          String?
  phone          String?
  country        String?
  region         String?
  city           String?
  address        String?
  postalCode     String?   @map("postal_code")
  website        String?
  industry       String?
  companySize    String?   @map("company_size")
  description    String?
  stage          LeadStage @default(NEW)
  source         String?
  score          Int       @default(0)
  isPublicPool   Boolean   @default(false) @map("is_public_pool")
  estimatedValue Decimal?  @map("estimated_value") @db.Decimal(12, 2)
  currency       String?   @default("USD")
  expectedAmount Decimal?  @map("expected_amount") @db.Decimal(12, 2)
  expectedDate   DateTime? @map("expected_date")
  lastContactAt  DateTime? @map("last_contact_at")
  nextFollowUpAt DateTime? @map("next_follow_up_at")
  notes          String?
  priority       Int       @default(0)
  customerId     String?   @map("customer_id")
  ownerId        String?   @map("owner_id")
  creatorId      String?   @map("creator_id")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  owner      User?          @relation("LeadsOwned", fields: [ownerId], references: [id])
  creator    User?          @relation("LeadsCreated", fields: [creatorId], references: [id])
  customer   Customer?      @relation(fields: [customerId], references: [id])
  activities LeadActivity[]

  @@map("leads")
}

model LeadActivity {
  id        String   @id @default(uuid())
  content   String
  leadId    String   @map("lead_id")
  ownerId   String   @map("owner_id")
  createdAt DateTime @default(now()) @map("created_at")

  lead  Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)
  owner User @relation(fields: [ownerId], references: [id])

  @@map("lead_activities")
}

// ==================== 邮件 ====================
enum EmailDirection {
  INBOUND
  OUTBOUND
}

enum EmailStatus {
  DRAFT
  SENT
  RECEIVED
  FAILED
  READ
  VIEWED
}

model Email {
  id            String         @id @default(uuid())
  messageId     String?        @unique @map("message_id")
  threadId      String?        @map("thread_id")
  emailConfigId String?        @map("email_config_id")
  fromAddr      String         @map("from_addr")
  toAddr        String         @map("to_addr")
  cc            String?
  bcc           String?
  subject       String
  bodyHtml      String?        @map("body_html")
  bodyText      String?        @map("body_text")
  direction     EmailDirection
  status        EmailStatus    @default(DRAFT)
  category      String?        @default("inbox")
  flagged       Boolean        @default(false)
  sentAt        DateTime?      @map("sent_at")
  receivedAt    DateTime?      @map("received_at")
  // Legacy fields kept for backward compat with the existing UI:
  //   viewedAt  = first pixel load (any kind, incl. prefetch)
  //   viewCount = raw pixel hit counter (may be inflated by proxies)
  viewedAt      DateTime?      @map("viewed_at")
  viewCount     Int            @default(0) @map("view_count")
  // ---- Multi-signal tracking ----
  // First time a HUMAN open signal was registered (not prefetch/proxy).
  firstHumanOpenAt DateTime?   @map("first_human_open_at")
  // Latest open (any kind).
  lastOpenedAt     DateTime?   @map("last_opened_at")
  // Total click-through events on any tracked link.
  totalClicks      Int         @default(0) @map("total_clicks")
  // 0..1 confidence that the recipient has actually read the email.
  // Computed deterministically from open / click events — see
  // EmailTrackingService.computeConfidence().
  openConfidence   Float       @default(0) @map("open_confidence")
  // ---- Campaign / recipient grouping ----
  // Optional. Populated automatically on send:
  //   recipientId — upserted EmailRecipient keyed by toAddr (for
  //                 cross-email aggregation: "how many of john@foo.com's
  //                 emails has he opened?").
  //   campaignId  — set when SendEmailDto carries one (e.g. marketing blast).
  campaignId       String?     @map("campaign_id")
  recipientId      String?     @map("recipient_id")
  customerId    String?        @map("customer_id")
  senderId      String?        @map("sender_id")
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")

  thread       EmailThread?    @relation(fields: [threadId], references: [id])
  emailConfig  EmailConfig?    @relation("EmailAccount", fields: [emailConfigId], references: [id], onDelete: Cascade)
  customer     Customer?       @relation(fields: [customerId], references: [id])
  sender       User?           @relation("SentEmails", fields: [senderId], references: [id])
  openEvents   EmailOpenEvent[]
  clickEvents  EmailClickEvent[]
  links        EmailLink[]
  campaign     EmailCampaign?  @relation("CampaignEmails", fields: [campaignId], references: [id])
  recipient    EmailRecipient? @relation("RecipientEmails", fields: [recipientId], references: [id])

  @@index([campaignId])
  @@index([recipientId])
  @@map("emails")
}

// ==================== 邮件活动 (Campaign) ====================
// A campaign groups outbound emails that belong to the same outreach /
// marketing batch. Use it when you want aggregate open/click stats like
// "Q1 跟进 — 打开率 42%". Optional: regular 1-1 emails can skip it.
model EmailCampaign {
  id          String    @id @default(uuid())
  name        String
  description String?
  createdById String    @map("created_by_id")
  status      String    @default("DRAFT")  // DRAFT | SENDING | SENT | ARCHIVED
  sentAt      DateTime? @map("sent_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  creator User    @relation("CampaignsCreated", fields: [createdById], references: [id])
  emails  Email[] @relation("CampaignEmails")

  @@index([createdById])
  @@map("email_campaigns")
}

// ==================== 邮件收件人 (Recipient) ====================
// Canonical row per email address we've ever sent to. Auto-upserted at
// send time so opens / clicks across *multiple* emails can be aggregated
// per-person ("john@foo.com opened 4 of our 6 emails, clicked 2").
// Optionally linked to a CRM Customer / Contact if the address matches.
model EmailRecipient {
  id            String    @id @default(uuid())
  emailAddr     String    @unique @map("email_addr")
  name          String?
  customerId    String?   @map("customer_id")
  contactId     String?   @map("contact_id")
  firstSeenAt   DateTime  @default(now()) @map("first_seen_at")
  lastSentAt    DateTime? @map("last_sent_at")
  lastOpenedAt  DateTime? @map("last_opened_at")
  lastClickedAt DateTime? @map("last_clicked_at")
  totalSent     Int       @default(0) @map("total_sent")
  totalOpens    Int       @default(0) @map("total_opens")
  totalClicks   Int       @default(0) @map("total_clicks")

  emails Email[] @relation("RecipientEmails")

  @@map("email_recipients")
}

// ==================== 邮件追踪：打开事件 ====================
// Every pixel hit (after dedup) produces a row here. Even Gmail proxy /
// Apple Mail Privacy Protection prefetches are recorded — they just get
// a non-HUMAN `kind`, which the confidence scorer weights lower.
model EmailOpenEvent {
  id        String   @id @default(uuid())
  emailId   String   @map("email_id")
  email     Email    @relation(fields: [emailId], references: [id], onDelete: Cascade)
  openedAt  DateTime @default(now()) @map("opened_at")
  ip        String?
  userAgent String?  @map("user_agent") @db.Text
  referer   String?  @db.Text
  // HUMAN   : UA is a real mail client rendering images
  // PROXY   : Gmail image proxy / Yahoo Mail proxy
  // PREFETCH: Apple Mail Privacy Protection / background fetchers
  // BOT     : link scanners / crawlers / security gateways
  // DUP     : same IP+UA fired within the dedup window
  kind      String   @default("HUMAN")
  // Optional source marker: PIXEL (default) | CLICK_INFERRED
  source    String   @default("PIXEL")

  @@index([emailId])
  @@index([openedAt])
  @@map("email_open_events")
}

// ==================== 邮件追踪：点击事件 ====================
// Produced by the click redirect endpoint. A click is the strongest
// evidence of a real human read (images can be blocked, but following
// a link requires the user to act).
model EmailClickEvent {
  id        String   @id @default(uuid())
  emailId   String   @map("email_id")
  email     Email    @relation(fields: [emailId], references: [id], onDelete: Cascade)
  linkId    String   @map("link_id")
  url       String   @db.Text
  clickedAt DateTime @default(now()) @map("clicked_at")
  ip        String?
  userAgent String?  @map("user_agent") @db.Text
  referer   String?  @db.Text
  kind      String   @default("HUMAN")

  @@index([emailId])
  @@index([clickedAt])
  @@map("email_click_events")
}

// ==================== 邮件追踪：被重写的链接 ====================
// The HTML of outbound emails is rewritten at send-time so every <a href>
// becomes /api/emails/track/:emailId/click/:linkId. We persist the
// original URL + deterministic linkId so the click endpoint can redirect
// and so admins can see "which links were in the email".
model EmailLink {
  id       String @id @default(uuid())
  emailId  String @map("email_id")
  email    Email  @relation(fields: [emailId], references: [id], onDelete: Cascade)
  linkId   String @map("link_id")
  url      String @db.Text
  label    String? @db.Text
  position Int    @default(0)

  @@unique([emailId, linkId])
  @@index([emailId])
  @@map("email_links")
}

model EmailThread {
  id        String   @id @default(uuid())
  subject   String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  emails Email[]

  @@index([subject])
  @@map("email_threads")
}

model EmailTemplate {
  id        String   @id @default(uuid())
  name      String
  subject   String
  bodyHtml  String   @map("body_html")
  category  String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("email_templates")
}

// ==================== 报价单 ====================
enum QuotationStatus {
  DRAFT
  SENT
  VIEWED
  ACCEPTED
  REJECTED
  EXPIRED
}

model Quotation {
  id           String          @id @default(uuid())
  quotationNo  String          @unique @map("quotation_no")
  customerId   String          @map("customer_id")
  ownerId      String          @map("owner_id")
  title        String
  currency     String          @default("USD")
  totalAmount  Decimal         @default(0) @map("total_amount") @db.Decimal(12, 2)
  status       QuotationStatus @default(DRAFT)
  validUntil   DateTime?       @map("valid_until")
  terms        String?
  remark       String?
  pdfUrl       String?         @map("pdf_url")
  createdAt    DateTime        @default(now()) @map("created_at")
  updatedAt    DateTime        @updatedAt @map("updated_at")

  customer Customer        @relation(fields: [customerId], references: [id])
  owner    User            @relation(fields: [ownerId], references: [id])
  items    QuotationItem[]

  @@map("quotations")
}

model QuotationItem {
  id          String  @id @default(uuid())
  quotationId String  @map("quotation_id")
  productName String  @map("product_name")
  description String?
  unit        String  @default("PCS")
  quantity    Int
  unitPrice   Decimal @map("unit_price") @db.Decimal(12, 2)
  totalPrice  Decimal @map("total_price") @db.Decimal(12, 2)
  sortOrder   Int     @default(0) @map("sort_order")

  quotation Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)

  @@map("quotation_items")
}

// ==================== 形式发票 (PI) ====================
enum PIStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  REJECTED
}

enum TradeTermType {
  EXW
  FOB
  CIF
  CIP
  DPU
  DDP
  FCA
  FAS
  CFR
}

enum PaymentTermType {
  T_30
  T_50
  T_70
  T_100
}

model ProformaInvoice {
  id                 String          @id @default(uuid())
  piNo               String          @unique @map("pi_no")
  customerId         String          @map("customer_id")
  ownerId            String          @map("owner_id")
  status             PIStatus        @default(DRAFT)
  sellerId           String?         @map("seller_id")
  sellerAddress      String?         @map("seller_address")
  consigneeName      String?         @map("consignee_name")
  consigneeAddress   String?         @map("consignee_address")
  poNo               String?         @map("po_no")
  currency           String          @default("USD")
  tradeTerm          TradeTermType?  @map("trade_term")
  paymentTerm        PaymentTermType? @map("payment_term")
  shippingMethod     String?         @map("shipping_method")
  portOfLoading      String?         @map("port_of_loading")
  portOfDischarge    String?         @map("port_of_discharge")
  placeOfDelivery    String?         @map("place_of_delivery")
  paymentMethod      String?         @map("payment_method")
  countryOfOrigin    String?         @map("country_of_origin")
  termsOfDelivery    String?         @map("terms_of_delivery")
  notes              String?
  validityPeriod     Int             @default(7) @map("validity_period")
  subtotal           Decimal         @default(0) @db.Decimal(12, 2)
  shippingCharge     Decimal         @default(0) @map("shipping_charge") @db.Decimal(12, 2)
  other              Decimal         @default(0) @db.Decimal(12, 2)
  totalAmount        Decimal         @default(0) @map("total_amount") @db.Decimal(12, 2)
  bankAccountId      String?         @map("bank_account_id")
  templateId         String?         @map("template_id")
  approverId         String?         @map("approver_id")
  approvedAt         DateTime?       @map("approved_at")
  rejectionReason    String?         @map("rejection_reason")
  createdAt          DateTime        @default(now()) @map("created_at")
  updatedAt          DateTime        @updatedAt @map("updated_at")

  customer    Customer                @relation(fields: [customerId], references: [id])
  owner       User                    @relation("PIsOwned", fields: [ownerId], references: [id])
  approver    User?                   @relation("PIsApproved", fields: [approverId], references: [id])
  bankAccount BankAccount?            @relation(fields: [bankAccountId], references: [id])
  template    PITemplate?             @relation(fields: [templateId], references: [id])
  items       ProformaInvoiceItem[]

  @@index([piNo])
  @@index([customerId])
  @@index([ownerId])
  @@index([status])
  @@index([bankAccountId])
  @@index([templateId])
  @@map("proforma_invoices")
}

// ==================== 银行账户（收款账户） ====================
// 公司可同时维护多个收款账户（USD/EUR/CNY 户等），开 PI 时按需选择。
// `alias` 是下拉里展示的简称（如 "招行 USD"），`bankInfoText` 是会
// 直接拼到 PI PDF "Bank Information" 区域的多行文本，每行一条。
model BankAccount {
  id            String   @id @default(uuid())
  alias         String   // 简称，下拉选择显示
  bankInfoText  String   @map("bank_info_text") @db.Text  // 完整银行信息（多行）
  isDefault     Boolean  @default(false) @map("is_default")
  sortOrder     Int      @default(0) @map("sort_order")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  proformaInvoices ProformaInvoice[]
  templates        PITemplate[]

  @@index([isDefault])
  @@index([sortOrder])
  @@map("bank_accounts")
}

// ==================== 形式发票模板 ====================
// 管理员可以预设多个 PI 模板（例如：海运默认、样品单、空运默认），
// 每个模板记录该场景下常用的贸易条款、付款方式、运输方式等字段；
// 业务员开 PI 时选一个模板即可自动填充，不用每次手动输入。
model PITemplate {
  id               String           @id @default(uuid())
  name             String           // 模板名称（如："海运 CIF 模板"）
  description      String?
  isDefault        Boolean          @default(false) @map("is_default")

  currency         String?          @default("USD")
  tradeTerm        TradeTermType?   @map("trade_term")
  paymentTerm      PaymentTermType? @map("payment_term")
  shippingMethod   String?          @map("shipping_method")
  paymentMethod    String?          @map("payment_method")
  portOfLoading    String?          @map("port_of_loading")
  portOfDischarge  String?          @map("port_of_discharge")
  placeOfDelivery  String?          @map("place_of_delivery")
  countryOfOrigin  String?          @map("country_of_origin")
  termsOfDelivery  String?          @map("terms_of_delivery") @db.Text
  notes            String?          @db.Text
  validityPeriod   Int?             @map("validity_period")
  bankAccountId    String?          @map("bank_account_id")

  sortOrder        Int              @default(0) @map("sort_order")
  createdAt        DateTime         @default(now()) @map("created_at")
  updatedAt        DateTime         @updatedAt @map("updated_at")

  bankAccount      BankAccount?     @relation(fields: [bankAccountId], references: [id])
  proformaInvoices ProformaInvoice[]

  @@index([isDefault])
  @@index([sortOrder])
  @@map("pi_templates")
}

model ProformaInvoiceItem {
  id          String  @id @default(uuid())
  piId        String  @map("pi_id")
  productName String  @map("product_name")
  description String?
  hsn         String?
  unit        String  @default("PCS")
  quantity    Int
  unitPrice   Decimal @map("unit_price") @db.Decimal(12, 2)
  totalPrice  Decimal @map("total_price") @db.Decimal(12, 2)
  sortOrder   Int     @default(0) @map("sort_order")

  pi ProformaInvoice @relation(fields: [piId], references: [id], onDelete: Cascade)

  @@map("proforma_invoice_items")
}

// ==================== 订单 ====================
enum OrderStatus {
  PENDING
  CONFIRMED
  IN_PRODUCTION
  SHIPPED
  DELIVERED
  CANCELLED
}

enum PaymentStatus {
  UNPAID
  PARTIAL
  PAID
  REFUNDED
}

model Order {
  id            String        @id @default(uuid())
  orderNo       String        @unique @map("order_no")
  customerId    String        @map("customer_id")
  ownerId       String        @map("owner_id")
  title         String
  currency      String        @default("USD")
  totalAmount   Decimal       @default(0) @map("total_amount") @db.Decimal(12, 2)
  status        OrderStatus   @default(PENDING)
  paymentStatus PaymentStatus @default(UNPAID) @map("payment_status")
  costTypes     String[]      @default([]) @map("cost_types")
  floorPrice    Decimal?      @map("floor_price") @db.Decimal(12, 2)
  shippingAddr  String?       @map("shipping_addr")
  shippingDate  DateTime?     @map("shipping_date")
  deliveryDate  DateTime?     @map("delivery_date")
  trackingNo    String?       @map("tracking_no")
  remark        String?
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  customer Customer    @relation(fields: [customerId], references: [id])
  owner    User        @relation(fields: [ownerId], references: [id])
  items    OrderItem[]

  @@map("orders")
}

model OrderItem {
  id          String  @id @default(uuid())
  orderId     String  @map("order_id")
  productName String  @map("product_name")
  description String?
  unit        String  @default("PCS")
  quantity    Int
  unitPrice   Decimal @map("unit_price") @db.Decimal(12, 2)
  totalPrice  Decimal @map("total_price") @db.Decimal(12, 2)
  sortOrder   Int     @default(0) @map("sort_order")

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("order_items")
}

// ==================== 任务与跟进 ====================
enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

model Task {
  id          String       @id @default(uuid())
  title       String
  description String?
  priority    TaskPriority @default(MEDIUM)
  status      TaskStatus   @default(PENDING)
  dueDate     DateTime?    @map("due_date")
  ownerId     String       @map("owner_id")
  relatedType String?      @map("related_type")
  relatedId   String?      @map("related_id")
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  owner User @relation(fields: [ownerId], references: [id])

  @@map("tasks")
}

// ==================== 客户活动记录 ====================
enum ActivityType {
  NOTE
  CALL
  MEETING
  EMAIL
  TASK
  STATUS_CHANGE
  PRICE_DISCUSSION
  ORDER_INTENT
  SAMPLE
  MOLD_FEE
  PAYMENT
  SHIPPING
  COMPLAINT
  VISIT
}

model Activity {
  id          String       @id @default(uuid())
  type        ActivityType
  content     String
  customerId  String?      @map("customer_id")
  ownerId     String       @map("owner_id")
  relatedType String?      @map("related_type")
  relatedId   String?      @map("related_id")
  createdAt   DateTime     @default(now()) @map("created_at")

  customer Customer? @relation(fields: [customerId], references: [id])
  owner    User      @relation(fields: [ownerId], references: [id])

  @@map("activities")
}

// ==================== 文件管理 ====================
model Document {
  id          String   @id @default(uuid())
  fileName    String   @map("file_name")
  filePath    String   @map("file_path")
  fileSize    Int      @map("file_size")
  mimeType    String   @map("mime_type")
  category    String?
  customerId  String?  @map("customer_id")
  ownerId     String   @map("owner_id")
  relatedType String?  @map("related_type")
  relatedId   String?  @map("related_id")
  createdAt   DateTime @default(now()) @map("created_at")

  customer Customer? @relation(fields: [customerId], references: [id])
  owner    User      @relation(fields: [ownerId], references: [id])

  @@map("documents")
}

// ==================== 备忘录 ====================
model Memo {
  id        String   @id @default(uuid())
  title     String
  content   String?
  color     String?  @default("#ffffff")
  date      DateTime @default(now())
  ownerId   String   @map("owner_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  owner User @relation(fields: [ownerId], references: [id])

  @@map("memos")
}

// ==================== 站内消息 ====================
model Message {
  id        String   @id @default(uuid())
  fromId    String   @map("from_id")
  toId      String   @map("to_id")
  content   String
  isRead    Boolean  @default(false) @map("is_read")
  createdAt DateTime @default(now()) @map("created_at")

  from User @relation("MessagesSent", fields: [fromId], references: [id], onDelete: Cascade)
  to   User @relation("MessagesReceived", fields: [toId], references: [id], onDelete: Cascade)

  @@index([toId, isRead])
  @@index([fromId])
  @@map("messages")
}

// ==================== 系统设置 ====================
model SystemSetting {
  id    String @id @default(uuid())
  key   String @unique
  value String
  label String?

  @@map("system_settings")
}
