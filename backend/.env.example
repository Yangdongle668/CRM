# 数据库配置
DATABASE_URL="postgresql://crm_user:crm_password@localhost:5432/trade_crm?schema=public"

# Redis配置（BullMQ 异步队列 & WebSocket 所需）
# 可使用完整 URL（推荐）或拆分字段，任一即可
# REDIS_URL=redis://:password@localhost:6379/0
REDIS_HOST=localhost
REDIS_PORT=6379
# REDIS_PASSWORD=
# REDIS_DB=0

# JWT配置
JWT_SECRET=your-jwt-secret-key-change-in-production
JWT_EXPIRES_IN=7d

# 服务配置
PORT=3001
NODE_ENV=development
# WebSocket / 邮件追踪像素使用的对外访问地址
# ⚠️ 关键：必须是收件人邮件客户端能访问到的域名，不能是 docker 内部 service 名。
# 生产示例：APP_URL=https://crm.07691688.xyz
APP_URL=http://localhost:3001
# 允许跨域的来源（WebSocket 与 REST 均适用）
CORS_ORIGIN=http://localhost:3000
# 点击追踪 HMAC 秘钥（不设则回落到 JWT_SECRET）
# EMAIL_TRACKING_SECRET=change-this-in-production

# 文件上传
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760

# 邮件默认配置（用户可在系统设置中自定义）
DEFAULT_SMTP_HOST=smtp.example.com
DEFAULT_SMTP_PORT=465
DEFAULT_IMAP_HOST=imap.example.com
DEFAULT_IMAP_PORT=993
